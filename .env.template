# =====================================================
# MentorHub - Configuration Template
# Скопируйте в .env и настройте под свою среду
# cp .env.template .env
# =====================================================

# ==================== APPLICATION ====================
# Имя приложения и версия (для логирования)
APP_NAME=MentorHub API
APP_VERSION=1.0.0

# Режим отладки (True/False)
DEBUG=False

# Окружение: development, staging, production
ENVIRONMENT=development

# ==================== PORTS ====================
# Порты для всех сервисов (автоматически определяются скриптом auto-ports.sh)
# Если порт занят, укажите другой - всё заработает автоматически

# Backend API (FastAPI/Uvicorn)
BACKEND_PORT=8000

# Frontend (Next.js)
FRONTEND_PORT=3000

# PostgreSQL Database
DB_PORT=5432

# Redis Cache
REDIS_PORT=6379

# Nginx Reverse Proxy (HTTP)
# Внимание: порты < 1024 требуют root/admin прав
NGINX_HTTP_PORT=80

# Nginx Reverse Proxy (HTTPS)
NGINX_HTTPS_PORT=443

# Prometheus Monitoring
PROMETHEUS_PORT=9090

# Grafana Dashboard
GRAFANA_PORT=3001

# ==================== SERVER ====================
# Хост для прослушивания (0.0.0.0 для внешней доступности)
HOST=0.0.0.0
PORT=${BACKEND_PORT}

# ==================== DATABASE ====================
# PostgreSQL credentials
# ВАЖНО: Смените пароль для production!
DB_USER=mentorhub_user
DB_PASSWORD=change-this-password-in-production
DB_NAME=mentorhub_dev

# Database connection URL (автоматически собирается из переменных)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:${DB_PORT}/${DB_NAME}

# Database performance
DB_ECHO=False
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ==================== REDIS ====================
REDIS_URL=redis://redis:${REDIS_PORT}/0
REDIS_HOST=redis
REDIS_PORT=${REDIS_PORT}
REDIS_DB=0

# ==================== JWT AUTHENTICATION ====================
# ВАЖНО: Сгенерируйте ключ: openssl rand -hex 32
SECRET_KEY=change-this-secret-key-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== CORS ====================
# Укажите URL вашего фронтенда
# Development:
CORS_ORIGINS=http://localhost:${FRONTEND_PORT},http://localhost:${BACKEND_PORT},http://127.0.0.1:${FRONTEND_PORT},http://127.0.0.1:${BACKEND_PORT}
# Production (раскомментируйте и измените):
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ==================== AGORA VIDEO ====================
# Для видеозвонков в менторских сессиях
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-certificate

# ==================== STRIPE PAYMENTS ====================
# Для приёма оплат
STRIPE_API_KEY=your-stripe-api-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_MOCK_MODE=True  # True для тестирования

# ==================== SBP (Система Быстрых Платежей) ====================
# Для приёма оплат через СБП (Россия)
SBP_MERCHANT_ID=your-sbp-merchant-id
SBP_API_KEY=your-sbp-api-key
SBP_API_SECRET=your-sbp-api-secret
SBP_CALLBACK_URL=http://localhost:${BACKEND_PORT}/api/payments/sbp/callback
SBP_MOCK_MODE=True

# ==================== EMAIL (SMTP) ====================
# Для отправки уведомлений на email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@mentorhub.com
SMTP_FROM_NAME=MentorHub

# ==================== FRONTEND ====================
# URL API для фронтенда (публичный)
NEXT_PUBLIC_API_URL=http://localhost:${BACKEND_PORT}
NEXT_PUBLIC_API_BASE_URL=http://localhost:${BACKEND_PORT}/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:${FRONTEND_PORT}

# ==================== MONITORING ====================
# Grafana credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ==================== OPTIONAL SERVICES ====================
# Sentry - отслеживание ошибок
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Cloudinary - хранение изображений
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Telegram - уведомления админам
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AWS S3 - облачное хранилище
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
