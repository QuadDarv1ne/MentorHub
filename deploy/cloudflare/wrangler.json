{
  "name": "mentorhub-frontend",
  "compatibility_date": "2024-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "pages_build_output_dir": "frontend/.next",
  "functions": {
    "directory": "frontend/functions",
    "nodejs_compat": true
  },
  "env": {
    "production": {
      "NEXT_PUBLIC_API_URL": "https://api.mentorhub.com",
      "NODE_ENV": "production"
    },
    "staging": {
      "NEXT_PUBLIC_API_URL": "https://staging-api.mentorhub.com",
      "NODE_ENV": "staging"
    }
  },
  "routes": [
    {
      "pattern": "mentorhub.com/api/*",
      "to": "https://api.mentorhub.com/api/*"
    }
  ],
  "headers": [
    {
      "pattern": "/*",
      "headers": {
        "X-Frame-Options": "DENY",
        "X-Content-Type-Options": "nosniff",
        "Strict-Transport-Security": "max-age=31536000; includeSubDomains; preload"
      }
    }
  ]
}
