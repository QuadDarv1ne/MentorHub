# Environment Variables Template
# Скопируйте этот файл в .env и заполните значения

# =============================================================================
# SECURITY
# =============================================================================
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/mentorhub

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=production
DEBUG=false
PORT=8000

# =============================================================================
# AGORA (Video Conferencing)
# =============================================================================
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# =============================================================================
# STRIPE (Payments)
# =============================================================================
STRIPE_API_KEY=sk_test_your-stripe-api-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# =============================================================================
# AWS S3 (File Storage)
# =============================================================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=mentorhub-bucket
AWS_REGION=eu-central-1

# =============================================================================
# EMAIL (SMTP)
# =============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_SENDER=noreply@mentorhub.com
EMAIL_USE_TLS=true

# =============================================================================
# CELERY
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# MONITORING
# =============================================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=http://localhost:3000,https://mentorhub.com
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
